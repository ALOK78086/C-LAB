using System;

class Program
{
    static void Main()
    {
        try
        {
            int a = 10, b = 0;
            int result = a / b;   // Error: Divide by zero
            Console.WriteLine("Result: " + result);
        }
        catch (Exception e)
        {
            Console.WriteLine("Exception caught: " + e.Message);
        }
    }
}
