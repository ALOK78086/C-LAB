// Write a program to check whether a number is perfect or not
using System;
class Program
{
    static void Main()
    {
        int n, sum = 0;
        Console.Write("Enter number: ");
        n = Convert.ToInt32(Console.ReadLine());

        for (int i = 1; i < n; i++)
        {
            if (n % i == 0)
                sum += i;
        }

        if (sum == n)
            Console.WriteLine("Perfect Number");
        else
            Console.WriteLine("Not Perfect");
    }
}
