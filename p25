// Write a program to check whether a number is neon number or not
using System;
class Program
{
    static void Main()
    {
        int n, sum = 0;
        Console.Write("Enter number: ");
        n = Convert.ToInt32(Console.ReadLine());

        int square = n * n;

        while (square > 0)
        {
            sum += square % 10;
            square /= 10;
        }

        if (sum == n)
            Console.WriteLine("Neon Number");
        else
            Console.WriteLine("Not Neon");
    }
}
