🔹 1. Number Palindrome
using System;

class Program
{
    static void Main()
    {
        int n, rev = 0, temp;

        Console.Write("Enter number: ");
        n = Convert.ToInt32(Console.ReadLine());
        temp = n;

        while (n > 0)
        {
            rev = rev * 10 + n % 10;
            n = n / 10;
        }

        if (temp == rev)
            Console.WriteLine("Palindrome");
        else
            Console.WriteLine("Not Palindrome");
    }
}
🔹 2. String Palindrome
using System;

class Program
{
    static void Main()
    {
        string str, rev = "";

        Console.Write("Enter string: ");
        str = Console.ReadLine();

        for (int i = str.Length - 1; i >= 0; i--)
        {
            rev += str[i];
        }

        if (str == rev)
            Console.WriteLine("Palindrome");
        else
            Console.WriteLine("Not Palindrome");
    }
}
🔹 3. Armstrong Number
using System;

class Program
{
    static void Main()
    {
        int n, sum = 0, temp, rem;

        Console.Write("Enter number: ");
        n = Convert.ToInt32(Console.ReadLine());
        temp = n;

        while (n > 0)
        {
            rem = n % 10;
            sum += rem * rem * rem;
            n = n / 10;
        }

        if (temp == sum)
            Console.WriteLine("Armstrong Number");
        else
            Console.WriteLine("Not Armstrong");
    }
}
